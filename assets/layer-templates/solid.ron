// Solid layer: the base quad rasterized with a color constant
// (REQ-LAYER-008: In → Rasterize(color ← RGB Color) → Out).
LayerTemplate(
    key: "solid",
    display_name: "Solid",
    nodes: [
        TemplateNode(
            key: "in",
            type_key: "net.in",
            label: Some("In"),
            position: (-360.0, 0.0),
            outputs: [
                OutputPort(name: "base_geometry", data_type: DataTypeId(50)),
                OutputPort(name: "t", data_type: DataTypeId(10)),
            ],
        ),
        TemplateNode(
            key: "color",
            type_key: "constant.color",
            position: (-360.0, 180.0),
        ),
        TemplateNode(
            key: "rasterize",
            type_key: "rasterize",
            position: (-120.0, 0.0),
        ),
        TemplateNode(
            key: "out",
            type_key: "net.out",
            label: Some("Out"),
            position: (120.0, 0.0),
            inputs: [
                InputPort(name: "frame", accepted_types: [DataTypeId(1)]),
            ],
        ),
    ],
    edges: [
        TemplateEdge(from: ("in", "base_geometry"), to: ("rasterize", "geometry")),
        TemplateEdge(from: ("color", "color"), to: ("rasterize", "color")),
        TemplateEdge(from: ("rasterize", "output"), to: ("out", "frame")),
    ],
)
